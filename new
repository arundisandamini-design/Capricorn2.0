  if (!profile) return;
  const t = today();
  const yesterday = new Date(new Date().setDate(new Date().getDate() - 1)).toISOString().slice(0, 10);
  if (profile.lastLogin === yesterday) {
    profile.streak = (profile.streak || 0) + 1;
  } else if (profile.lastLogin !== t) {
    profile.streak = 1;
  }
  profile.lastLogin = t;
  saveProfile(profile);
  document.getElementById('streak-count').textContent = profile.streak || 0;
  checkBadge('streak_3', profile.streak >= 3);
  checkBadge('streak_7', profile.streak >= 7);
}

// ─── DAILY CHALLENGE ───
function updateDailyChallenge() {
  // Use date as seed for consistent daily challenge
  const seed = new Date().getDate() + new Date().getMonth() * 31;
  const ch = CHALLENGES[seed % CHALLENGES.length];
  document.getElementById('daily-challenge-text').textContent = ch.text;
  const done = profile.challengeDoneToday === today();
  const btn = document.getElementById('challenge-btn');
  if (done) {
    btn.textContent = 'Completed! ✅';
    btn.disabled = true;
    btn.classList.add('opacity-50');
  }
}

function completeChallenge() {
  const seed = new Date().getDate() + new Date().getMonth() * 31;
  const ch = CHALLENGES[seed % CHALLENGES.length];
  addXP(ch.xp);
  profile.challengesDone = (profile.challengesDone || 0) + 1;
  profile.challengeDoneToday = today();
  saveProfile(profile);
  showToast(`+${ch.xp} XP! Challenge complete! 🎉`);
  updateDailyChallenge();
  checkBadge('challenge_5', profile.challengesDone >= 5);
}

// ─── TABS ───
function switchTab(tabName) {
  document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
  document.querySelectorAll('[data-tab]').forEach(b => {
    b.classList.remove('tab-active');
    b.classList.add('tab-inactive');
  });
  document.getElementById('tab-' + tabName).style.display = tabName === 'chat' ? 'flex' : 'block';
  const btn = document.querySelector(`[data-tab="${tabName}"]`);
  if (btn) { btn.classList.remove('tab-inactive'); btn.classList.add('tab-active'); }
}

// ─── DASHBOARD ───
function updateDashboard() {
  const todayEntries = getTodayData();
  const totalCal = todayEntries.filter(r => r.type === 'meal').reduce((s, r) => s + (r.calories || 0), 0);
  const waterCount = todayEntries.filter(r => r.type === 'water').length;
  const workoutDone = todayEntries.some(r => r.type === 'workout');
  const target = calcBMR();
  const calPct = Math.min(totalCal / target, 1);
  const waterPct = Math.min(waterCount / 8, 1);
  const wPct = workoutDone ? 1 : 0;
  const circ = 175.9;
  document.getElementById('cal-ring').style.strokeDashoffset = circ * (1 - calPct);
  document.getElementById('cal-display').textContent = totalCal;
  document.getElementById('water-ring').style.strokeDashoffset = circ * (1 - waterPct);
  document.getElementById('water-display').textContent = waterCount + '/8';
  document.getElementById('workout-ring').style.strokeDashoffset = circ * (1 - wPct);
  document.getElementById('workout-display').textContent = workoutDone ? 'Yes!' : 'No';

  checkBadge('hydrated', waterCount >= 8);
  checkBadge('calories_1000', totalCal >= 1000);
}

