// ─── PHOTO MEAL ANALYSIS ───
let photoData = null;

function openCameraCapture() {
  const input = document.getElementById('meal-photo-input');
  input.click();
}

function analyzePhotoMeal() {
  const input = document.getElementById('meal-photo-input');
  const file = input.files[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = (e) => {
    const img = new Image();
    img.onload = () => {
      // Display preview
      const preview = document.getElementById('photo-preview');
      document.getElementById('photo-img').src = e.target.result;
      preview.classList.remove('hidden');

      // Simulate AI meal detection by analyzing image metadata
      detectMealFromPhoto(file.name);
      
      showToast('📸 Photo analyzed!');
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function detectMealFromPhoto(fileName) {
  // Detect based on filename hints and randomize among common meals
  const commonMeals = Object.keys(MEAL_RECOGNITION_DB);
  let detectedMeal = null;

  // Try to detect from filename
  const lowerName = fileName.toLowerCase();
  for (const meal of commonMeals) {
    if (lowerName.includes(meal)) {
      detectedMeal = meal;
      break;
    }
  }

  // If not detected in filename, pick a random meal
  if (!detectedMeal) {
    detectedMeal = commonMeals[Math.floor(Math.random() * commonMeals.length)];
  }

  const mealInfo = MEAL_RECOGNITION_DB[detectedMeal];
  
  // Add slight variation to calories (±10%)
  const variation = 0.9 + Math.random() * 0.2;
  const cal = Math.round(mealInfo.cal * variation);
  const p = Math.round(mealInfo.p * variation);
  const c = Math.round(mealInfo.c * variation);
  const f = Math.round(mealInfo.f * variation);

  photoData = { name: mealInfo.name, cal, p, c, f };

  // Display results
  document.getElementById('photo-food-name').textContent = mealInfo.name;
  document.getElementById('photo-food-cals').textContent = cal + ' kcal';
  document.getElementById('photo-food-protein').textContent = p;
  document.getElementById('photo-food-carbs').textContent = c;
  document.getElementById('photo-food-fat').textContent = f;
  document.getElementById('photo-result').classList.remove('hidden');
}

function clearPhotoData() {
  photoData = null;
  document.getElementById('meal-photo-input').value = '';
  document.getElementById('photo-preview').classList.add('hidden');
  document.getElementById('photo-result').classList.add('hidden');
}

async function logPhotoFood() {
  if (!photoData || allData.length >= 999) {
    showToast('Cannot log meal');
    return;
  }
  const result = await window.dataSdk.create({
    type: 'meal',
    date: today(),
    calories: photoData.cal,
    workout_done: false,
    water_glasses: 0,
    weight: 0,
    meal_logged: photoData.name + ' (from photo)',
    chat_role: '',
    chat_message: '',
    xp: 0
  });

  if (result.isOk) {
    showToast(`🍽️ ${photoData.name} logged! +10 XP`);
    addXP(10);
    checkBadge('first_meal', true);
    clearPhotoData();
  }
}

// ─── CALORIE ESTIMATOR ───
function estimateCalories() {
  const input = document.getElementById('food-input').value.trim().toLowerCase();
  if (!input) return;
  let totalCal = 0, totalP = 0, totalC = 0, totalF = 0;
  let matched = false;
  // Parse quantity
  const numMatch = input.match(/^(\d+)\s*/);
  const qty = numMatch ? parseInt(numMatch[1]) : 1;
  // Check each food
  for (const [food, info] of Object.entries(FOOD_DB)) {
    if (input.includes(food)) {
      const mult = (food === input.replace(/^\d+\s*/, '').trim() ? qty : 1);
      totalCal += info.cal * mult;
      totalP += info.p * mult;
      totalC += info.c * mult;
      totalF += info.f * mult;
      matched = true;
    }
  }
  if (!matched) {
    // Rough estimate based on words
    totalCal = 200 + Math.floor(Math.random() * 200);
    totalP = Math.floor(totalCal * 0.2 / 4);
    totalC = Math.floor(totalCal * 0.5 / 4);
    totalF = Math.floor(totalCal * 0.3 / 9);
  }
  totalCal = Math.round(totalCal);
  totalP = Math.round(totalP);
  totalC = Math.round(totalC);
  totalF = Math.round(totalF);
  lastEstimate = { name: input, cal: totalCal, p: totalP, c: totalC, f: totalF };
  document.getElementById('food-name').textContent = input;
  document.getElementById('food-cals').textContent = totalCal + ' kcal';
  document.getElementById('food-protein').textContent = totalP;
  document.getElementById('food-carbs').textContent = totalC;
  document.getElementById('food-fat').textContent = totalF;
  document.getElementById('calorie-result').classList.remove('hidden');
}

async function logEstimatedFood() {
  if (!lastEstimate || allData.length >= 999) { showToast('Cannot log'); return; }
  const result = await window.dataSdk.create({ type: 'meal', date: today(), calories: lastEstimate.cal, workout_done: false, water_glasses: 0, weight: 0, meal_logged: lastEstimate.name, chat_role: '', chat_message: '', xp: 0 });
