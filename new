// ─── HELPER FUNCTIONS ───
function showToast(msg) {
  const t = document.getElementById('toast');
  document.getElementById('toast-text').textContent = msg;
  t.style.opacity = '1';
  t.style.transform = 'translate(-50%, 0)';
  setTimeout(() => {
    t.style.opacity = '0';
    t.style.transform = 'translate(-50%, -20px)';
  }, 2500);
}

function getProfile() {
  try { return JSON.parse(localStorage.getItem('fc_profile')); } catch { return null; }
}
function saveProfile(p) {
  profile = p;
  localStorage.setItem('fc_profile', JSON.stringify(p));
}

function getTodayData() {
  const d = today();
  return allData.filter(r => r.date === d);
}

function calcBMI(weight = null, height = null) {
  let w = weight || parseFloat(document.getElementById('bmi-weight')?.value);
  let h = height || parseFloat(document.getElementById('bmi-height')?.value);
  
  if (!w || !h || w < 20 || w > 500 || h < 100 || h > 250) {
    if (document.getElementById('bmi-result')) {
      showToast('Enter valid weight and height');
    }
    return null;
  }
  
  const bmi = (w / ((h / 100) ** 2)).toFixed(1);
  let category = '';
  let categoryColor = '';
  
  if (bmi < 18.5) {
    category = '📉 Underweight - Consider gaining weight for health';
    categoryColor = 'text-blue-400';
  } else if (bmi < 25) {
    category = '✅ Normal Weight - Keep up healthy habits!';
    categoryColor = 'text-emerald-400';
  } else if (bmi < 30) {
    category = '⚠️ Overweight - Aim to lose weight gradually';
    categoryColor = 'text-amber-400';
  } else {
    category = '🔴 Obese - Consider consulting a healthcare provider';
    categoryColor = 'text-red-400';
  }
  
  const resultDiv = document.getElementById('bmi-result');
  if (resultDiv) {
    document.getElementById('bmi-value').textContent = bmi;
    document.getElementById('bmi-category').textContent = category;
    document.getElementById('bmi-category').className = `text-xs ${categoryColor} mb-3`;
    resultDiv.classList.remove('hidden');
    showToast(`BMI: ${bmi} - ${category.split(' - ')[0]}`);
  }
  
  return bmi;
}

function calcBMR() {
  if (!profile) return 2000;
  // Mifflin-St Jeor
  const w = profile.weight || 70;
  const h = profile.height || 170;
  const a = profile.age || 25;
  let bmr = 10 * w + 6.25 * h - 5 * a + 5;
  const mult = { sedentary: 1.2, light: 1.375, moderate: 1.55, active: 1.725 };
  let tdee = bmr * (mult[profile.activity] || 1.375);
  if (profile.goal === 'lose') tdee -= 400;
  if (profile.goal === 'gain') tdee += 400;
  return Math.round(tdee);
}

function getXP() {
  if (!profile) return 0;
  return profile.xp || 0;
}
function addXP(amount) {
  if (!profile) return;
  profile.xp = (profile.xp || 0) + amount;
  saveProfile(profile);
  updateXPDisplay();
}
function updateXPDisplay() {
  const xp = getXP();
  const level = Math.floor(xp / 100) + 1;
  const progress = (xp % 100);
  document.getElementById('level-num').textContent = level;
  document.getElementById('xp-bar').style.width = progress + '%';
  checkBadge('level_5', level >= 5);
}

function checkBadge(id, condition) {
  if (!profile || !condition) return;
  if (!profile.badges) profile.badges = [];
  if (!profile.badges.includes(id)) {
    profile.badges.push(id);
    saveProfile(profile);
    showToast('🏆 Badge unlocked!');
  }
}

