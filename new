let timerRunning = false;
let lastEstimate = null;
const today = () => new Date().toISOString().slice(0, 10);function checkVoiceSupport() {
  const status = document.getElementById('voice-status');
  if (!status) return;
  let html = '<div class="space-y-2">';
  html += SpeechRecognition ? '✅ <span class="text-emerald-400">Voice Recognition: Available</span>' : '❌ <span class="text-red-400">Voice Recognition: Not supported</span>';
  html += '<br>';
  html += SpeechSynthesis ? '✅ <span class="text-emerald-400">Text-to-Speech: Available</span>' : '❌ <span class="text-red-400">Text-to-Speech: Not supported</span>';
  html += '</div>';
  status.innerHTML = html;
}

function testMicrophone() {
  if (!SpeechRecognition) {
    showToast('Voice recognition not supported in this browser');
    return;
  }
  const btn = event.target;
  btn.disabled = true;
  btn.textContent = '🎤 Listening... (3 sec)';
  recognitionInstance = new SpeechRecognition();
  recognitionInstance.lang = 'en-US';
  recognitionInstance.onresult = (event) => {
    const text = event.results[0][0].transcript;
    showToast(`Heard: "${text}"`);
    btn.disabled = false;
    btn.textContent = 'Test Microphone';
  };
  recognitionInstance.onerror = () => {
    showToast('Microphone test failed');
    btn.disabled = false;
    btn.textContent = 'Test Microphone';
  };
  recognitionInstance.start();
}

function testSpeaker() {
  if (!SpeechSynthesis) {
    showToast('Text-to-speech not supported');
    return;
  }
  const utterance = new SpeechSynthesisUtterance('FlexCoach voice test. Hello, this is your health coach.');
  utterance.rate = 1;
  window.speechSynthesis.cancel();
  window.speechSynthesis.speak(utterance);
  showToast('🔊 Speaking...');
}

function toggleTextToSpeech() {
  textToSpeechEnabled = !textToSpeechEnabled;
  const toggle = document.getElementById('tts-toggle');
  if (toggle) {
    toggle.classList.toggle('ring-2', textToSpeechEnabled);
    toggle.classList.toggle('ring-purple-400', textToSpeechEnabled);
  }
  showToast(textToSpeechEnabled ? '🔊 Text-to-Speech ON' : '🔇 Text-to-Speech OFF');
  localStorage.setItem('fc_tts_enabled', textToSpeechEnabled);
}

function speakText(text) {
  if (!textToSpeechEnabled || !SpeechSynthesis) return;
  window.speechSynthesis.cancel();
  const utterance = new SpeechSynthesisUtterance(text);
  utterance.rate = 1;
  utterance.pitch = 1;
  window.speechSynthesis.speak(utterance);
}

function startVoiceInput(btn, callback) {
  if (!SpeechRecognition) {
    showToast('Voice recognition not available');
    return;
  }
  if (btn) {
    btn.classList.add('recording', 'voice-indicator');
    btn.innerHTML = '<i data-lucide="mic" style="width:18px;height:18px"></i>';
    lucide.createIcons();
  }
  recognitionInstance = new SpeechRecognition();
  recognitionInstance.lang = 'en-US';
  recognitionInstance.continuous = false;
  recognitionInstance.interimResults = false;
  recognitionInstance.onresult = (event) => {
    const transcript = event.results[0][0].transcript;
    if (btn) {
      btn.classList.remove('recording', 'voice-indicator');
      btn.innerHTML = '<i data-lucide="mic" style="width:16px;height:16px"></i>';
      lucide.createIcons();
    }
    callback(transcript);
  };
  recognitionInstance.onerror = () => {
    if (btn) {
      btn.classList.remove('recording', 'voice-indicator');
      btn.innerHTML = '<i data-lucide="mic" style="width:16px;height:16px"></i>';
      lucide.createIcons();
    }
    showToast('Voice input failed');
  };
  recognitionInstance.start();
}

function handleChatVoice() {
  if (!SpeechRecognition) {
    showToast('🎤 Voice not supported on this browser');
    return;
  }
  
  const btn = document.getElementById('chat-voice-btn');
  if (!btn) return;
  
  try {
    btn.classList.add('recording');
    btn.style.boxShadow = '0 0 20px rgba(239, 68, 68, 0.6)';
    showToast('🎤 Listening... speak now');
    
    const recognition = new SpeechRecognition();
    recognition.lang = 'en-US';
    recognition.continuous = false;
    recognition.interimResults = false;
    
    let hasResult = false;
    
    recognition.onresult = (event) => {
      hasResult = true;
      if (event.results && event.results[0]) {
        const transcript = event.results[0][0].transcript;
        if (transcript && transcript.trim()) {
          document.getElementById('chat-input').value = transcript;
          sendChat();
        }
      }
    };
    
    recognition.onerror = (event) => {
      if (event.error === 'no-speech') {
        showToast('🎤 No speech detected - try again');
      } else if (event.error === 'network') {
        showToast('🎤 Network error - check connection');
      } else {
        showToast('🎤 Error: ' + event.error);
      }
    };
    
    recognition.onend = () => {
      btn.classList.remove('recording');
      btn.style.boxShadow = '';
      if (!hasResult) {
        showToast('🎤 Say something to send');
      }
    };
    
    recognition.start();
  } catch (err) {
    btn.classList.remove('recording');
    btn.style.boxShadow = '';
    showToast('🎤 Voice error - try typing instead');
  }
}

function handleVoiceCommand(transcript) {
  const cmd = transcript.toLowerCase().trim();
  let handled = false;

  // Log water
  if (cmd.includes('water') || cmd.includes('drink')) {
    quickLogWater();
    handled = true;
  }
  // Log workout
  if (cmd.includes('workout') || cmd.includes('exercise')) {
    quickLogWorkout();
    handled = true;
  }
  // Generate meal plan
  if (cmd.includes('meal') || cmd.includes('food')) {
    generateMealPlan();
    showToast('📋 Meal plan generated');
    handled = true;
  }
  // Switch tabs by voice
  if (cmd.includes('home') || cmd.includes('dashboard')) {
    switchTab('dashboard');
    handled = true;
  }
  if (cmd.includes('meals') || cmd.includes('food')) {
    switchTab('meals');
    handled = true;
  }
  if (cmd.includes('workout') || cmd.includes('exercise')) {
    switchTab('workout');
    handled = true;
  }
  if (cmd.includes('chat') || cmd.includes('coach')) {
    switchTab('chat');
    handled = true;
  }
  if (cmd.includes('stats') || cmd.includes('progress')) {
    switchTab('progress');
    handled = true;
  }

  if (handled) {
    speakText('Command executed');
  } else {
    showToast(`Voice command: "${transcript}"`);
  }
}

