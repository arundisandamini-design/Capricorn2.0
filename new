<!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FlexCoach</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="https://cdn.jsdelivr.net/npm/lucide@0.263.0/dist/umd/lucide.min.js"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&amp;family=Space+Mono:wght@400;700&amp;display=swap" rel="stylesheet">
  <script>
tailwind.config = {
  theme: {
    extend: {
      fontFamily: {
        heading: ['Space Mono', 'monospace'],
        body: ['Outfit', 'sans-serif']
      }
    }
  }
}
</script>
  <style>
html, body { height: 100%; margin: 0; }
.app-shell { height: 100%; overflow: auto; }
.glow-green { box-shadow: 0 0 20px rgba(16,185,129,0.3); }
.glow-text { text-shadow: 0 0 20px rgba(16,185,129,0.5); }
@keyframes slideUp { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }
@keyframes pulse-ring { 0% { box-shadow: 0 0 0 0 rgba(16,185,129,0.4); } 70% { box-shadow: 0 0 0 10px rgba(16,185,129,0); } 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0); } }
.anim-up { animation: slideUp 0.4s ease-out both; }
.anim-up-1 { animation-delay: 0.05s; }
.anim-up-2 { animation-delay: 0.1s; }
.anim-up-3 { animation-delay: 0.15s; }
.anim-up-4 { animation-delay: 0.2s; }
.pulse-glow { animation: pulse-ring 2s infinite; }
.chat-bubble-ai { background: linear-gradient(135deg, #064e3b, #065f46); border-radius: 2px 16px 16px 16px; }
.chat-bubble-user { background: linear-gradient(135deg, #1e1b4b, #312e81); border-radius: 16px 2px 16px 16px; }
.tab-active { background: linear-gradient(135deg, #059669, #10b981); color: white; box-shadow: 0 4px 15px rgba(16,185,129,0.4); }
.tab-inactive { background: #1e1e2e; color: #9ca3af; }
.card-dark { background: #12121f; border: 1px solid #1e1e35; }
.input-dark { background: #0d0d1a; border: 1px solid #2d2d4a; color: #e5e7eb; }
.input-dark:focus { border-color: #10b981; outline: none; box-shadow: 0 0 0 2px rgba(16,185,129,0.2); }
.scrollbar-hide::-webkit-scrollbar { display: none; }
.scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
.progress-ring { transition: stroke-dashoffset 0.6s ease; }
</style>
  <style>body { box-sizing: border-box; }
.voice-indicator { animation: pulse-voice 1s infinite; }
@keyframes pulse-voice { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
.recording { box-shadow: 0 0 20px rgba(239, 68, 68, 0.6); }
</style>
 </head>
 <body class="h-full bg-[#0a0a14]">
  <div class="app-shell font-body text-gray-200" id="app"><!-- ONBOARDING -->
   <div id="onboarding-screen" class="h-full flex items-center justify-center p-4" style="display:none;">
    <div class="card-dark rounded-3xl p-8 max-w-md w-full anim-up">
     <div class="text-center mb-8">
      <div class="text-5xl mb-4">
       💪
      </div>
      <h1 class="font-heading text-2xl text-emerald-400 glow-text mb-2" id="onboard-title">FlexCoach</h1>
      <p class="text-gray-400" id="onboard-subtitle">Your AI Health Coach</p>
     </div>
     <div class="space-y-4">
      <div><label class="text-sm text-gray-400 mb-1 block">Your Name</label> <input id="ob-name" type="text" placeholder="Enter your name" class="input-dark w-full rounded-xl px-4 py-3 text-sm">
      </div>
      <div class="grid grid-cols-2 gap-3">
       <div><label class="text-sm text-gray-400 mb-1 block">Age</label> <input id="ob-age" type="number" placeholder="25" class="input-dark w-full rounded-xl px-4 py-3 text-sm">
       </div>
       <div><label class="text-sm text-gray-400 mb-1 block">Weight (kg)</label> <input id="ob-weight" type="number" placeholder="70" class="input-dark w-full rounded-xl px-4 py-3 text-sm">
       </div>
      </div>
      <div class="grid grid-cols-2 gap-3">
       <div><label class="text-sm text-gray-400 mb-1 block">Height (cm)</label> <input id="ob-height" type="number" placeholder="170" class="input-dark w-full rounded-xl px-4 py-3 text-sm">
       </div>
       <div><label class="text-sm text-gray-400 mb-1 block">Goal</label> <select id="ob-goal" class="input-dark w-full rounded-xl px-4 py-3 text-sm"> <option value="lose">Lose Weight</option> <option value="maintain">Maintain</option> <option value="gain">Build Muscle</option> </select>
       </div>
      </div>
      <div><label class="text-sm text-gray-400 mb-1 block">Activity Level</label> <select id="ob-activity" class="input-dark w-full rounded-xl px-4 py-3 text-sm"> <option value="sedentary">Sedentary</option> <option value="light">Lightly Active</option> <option value="moderate">Moderately Active</option> <option value="active">Very Active</option> </select>
      </div><button onclick="completeOnboarding()" class="w-full bg-gradient-to-r from-emerald-600 to-emerald-500 hover:from-emerald-500 hover:to-emerald-400 text-white font-semibold rounded-xl py-3 mt-2 transition-all glow-green"> Start My Journey 🚀 </button>
     </div>
    </div>
   </div><!-- VOICE SETUP MODAL -->
   <div id="voice-setup-modal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4" style="display:none;">
    <div class="card-dark rounded-3xl p-8 max-w-md w-full">
     <h2 class="font-heading text-xl text-emerald-400 mb-4">🎤 Voice &amp; Audio Setup</h2>
     <div class="space-y-3 mb-4">
      <div id="voice-status" class="text-sm text-gray-400">
       <p>Checking device capabilities...</p>
      </div><button onclick="testMicrophone()" id="test-mic-btn" class="w-full bg-blue-600 hover:bg-blue-500 text-white rounded-xl py-2.5 text-sm font-semibold transition-all">🎤 Test Microphone</button> <button onclick="testSpeaker()" class="w-full bg-purple-600 hover:bg-purple-500 text-white rounded-xl py-2.5 text-sm font-semibold transition-all">🔊 Test Speaker</button>
     </div><button onclick="toggleVoiceSetup()" class="w-full bg-gray-700 hover:bg-gray-600 text-white rounded-xl py-2.5 text-sm font-semibold">Done</button>
    </div>
   </div>
   <div id="main-app" class="h-full flex flex-col" style="display:none;"><!-- Header -->
    <header class="flex-shrink-0 px-4 pt-4 pb-2">
     <div class="flex items-center justify-between max-w-2xl mx-auto">
      <div>
       <h1 class="font-heading text-lg text-emerald-400 glow-text" id="main-title">FlexCoach</h1>
       <p class="text-xs text-gray-500" id="greeting-text">Welcome back</p>
      </div>
      <div class="flex items-center gap-3">
       <div class="text-right">
        <div class="text-xs text-gray-500">
         Level <span id="level-num">1</span>
        </div>
        <div class="w-20 h-1.5 bg-gray-800 rounded-full overflow-hidden">
         <div id="xp-bar" class="h-full bg-gradient-to-r from-emerald-500 to-green-400 rounded-full transition-all duration-500" style="width:0%"></div>
        </div>
       </div>
       <div id="streak-badge" class="flex items-center gap-1 bg-amber-900/40 border border-amber-600/40 rounded-full px-2.5 py-1"><span class="text-amber-400 text-xs">🔥</span> <span class="text-amber-400 text-xs font-bold" id="streak-count">0</span>
       </div>
      </div>
     </div>
    </header><!-- Tab Bar -->
    <nav class="flex-shrink-0 px-4 py-2">
     <div class="flex gap-1.5 max-w-2xl mx-auto bg-[#0d0d1a] rounded-2xl p-1.5"><button onclick="switchTab('dashboard')" data-tab="dashboard" class="tab-active flex-1 rounded-xl py-2 text-xs font-semibold transition-all flex items-center justify-center gap-1"> <i data-lucide="layout-dashboard" style="width:14px;height:14px"></i> Home </button> <button onclick="switchTab('meals')" data-tab="meals" class="tab-inactive flex-1 rounded-xl py-2 text-xs font-semibold transition-all flex items-center justify-center gap-1"> <i data-lucide="utensils" style="width:14px;height:14px"></i> Meals </button> <button onclick="switchTab('workout')" data-tab="workout" class="tab-inactive flex-1 rounded-xl py-2 text-xs font-semibold transition-all flex items-center justify-center gap-1"> <i data-lucide="dumbbell" style="width:14px;height:14px"></i> Workout </button> <button onclick="switchTab('chat')" data-tab="chat" class="tab-inactive flex-1 rounded-xl py-2 text-xs font-semibold transition-all flex items-center justify-center gap-1"> <i data-lucide="message-circle" style="width:14px;height:14px"></i> Coach </button> <button onclick="switchTab('progress')" data-tab="progress" class="tab-inactive flex-1 rounded-xl py-2 text-xs font-semibold transition-all flex items-center justify-center gap-1"> <i data-lucide="trending-up" style="width:14px;height:14px"></i> Stats </button>
     </div>
    </nav><!-- Content Area -->
    <main class="flex-1 overflow-auto px-4 pb-4 scrollbar-hide">
     <div class="max-w-2xl mx-auto"><!-- DASHBOARD TAB -->
      <div id="tab-dashboard" class="tab-content space-y-4"><!-- Daily Summary -->
       <div class="card-dark rounded-2xl p-5 anim-up">
        <h3 class="font-heading text-sm text-emerald-400 mb-4">Today's Progress</h3>
        <div class="grid grid-cols-3 gap-3">
         <div class="text-center">
          <div class="relative inline-block">
           <svg width="70" height="70" class="transform -rotate-90"><circle cx="35" cy="35" r="28" fill="none" stroke="#1e1e35" stroke-width="5" /> <circle id="cal-ring" cx="35" cy="35" r="28" fill="none" stroke="#10b981" stroke-width="5" stroke-linecap="round" stroke-dasharray="175.9" stroke-dashoffset="175.9" class="progress-ring" />
           </svg>
           <div class="absolute inset-0 flex items-center justify-center"><span id="cal-display" class="text-sm font-bold text-emerald-400">0</span>
           </div>
          </div>
          <p class="text-xs text-gray-500 mt-1">Calories</p>
         </div>
         <div class="text-center">
          <div class="relative inline-block">
           <svg width="70" height="70" class="transform -rotate-90"><circle cx="35" cy="35" r="28" fill="none" stroke="#1e1e35" stroke-width="5" /> <circle id="water-ring" cx="35" cy="35" r="28" fill="none" stroke="#3b82f6" stroke-width="5" stroke-linecap="round" stroke-dasharray="175.9" stroke-dashoffset="175.9" class="progress-ring" />
           </svg>
           <div class="absolute inset-0 flex items-center justify-center"><span id="water-display" class="text-sm font-bold text-blue-400">0</span>
           </div>
          </div>
          <p class="text-xs text-gray-500 mt-1">Water 💧</p>
         </div>
         <div class="text-center">
          <div class="relative inline-block">
           <svg width="70" height="70" class="transform -rotate-90"><circle cx="35" cy="35" r="28" fill="none" stroke="#1e1e35" stroke-width="5" /> <circle id="workout-ring" cx="35" cy="35" r="28" fill="none" stroke="#a855f7" stroke-width="5" stroke-linecap="round" stroke-dasharray="175.9" stroke-dashoffset="175.9" class="progress-ring" />
           </svg>
           <div class="absolute inset-0 flex items-center justify-center"><span id="workout-display" class="text-sm font-bold text-purple-400">No</span>
           </div>
          </div>
          <p class="text-xs text-gray-500 mt-1">Workout</p>
         </div>
        </div>
       </div><!-- Quick Actions -->
       <div class="grid grid-cols-2 gap-3 anim-up anim-up-1"><button onclick="quickLogWater()" class="card-dark rounded-2xl p-4 text-left hover:border-blue-500/50 transition-all group">
         <div class="text-2xl mb-2">
          💧
         </div>
         <div class="text-sm font-semibold">
          Log Water
         </div>
         <div class="text-xs text-gray-500">
          +1 glass
         </div></button> <button onclick="quickLogWorkout()" class="card-dark rounded-2xl p-4 text-left hover:border-purple-500/50 transition-all group">
         <div class="text-2xl mb-2">
          🏋️
         </div>
         <div class="text-sm font-semibold">
          Log Workout
         </div>
         <div class="text-xs text-gray-500">
          Mark complete
         </div></button>
       </div><!-- Daily Challenge -->
       <div class="anim-up anim-up-2" id="challenge-container">
        <div class="bg-gradient-to-r from-emerald-900/40 to-emerald-800/20 border border-emerald-500/30 rounded-2xl p-5">
         <div class="flex items-center gap-2 mb-2"><span class="text-lg">⚡</span>
          <h4 class="font-heading text-sm text-emerald-400">Daily Challenge</h4>
         </div>
         <p class="text-sm text-gray-300" id="daily-challenge-text">Loading...</p><button onclick="completeChallenge()" id="challenge-btn" class="mt-3 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-semibold rounded-lg px-4 py-2 transition-all"> Complete ✓ </button>
        </div>
       </div><!-- Calorie Estimator -->
       <div class="card-dark rounded-2xl p-5 anim-up anim-up-3">
        <h3 class="font-heading text-sm text-emerald-400 mb-3">🍽️ Quick Calorie Estimator</h3>
        <p class="text-xs text-gray-500 mb-3">Describe your food to estimate calories</p>
        <div class="flex gap-2"><input id="food-input" type="text" placeholder="e.g. 2 eggs and toast" class="input-dark flex-1 rounded-xl px-4 py-2.5 text-sm"> <button onclick="estimateCalories()" class="bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl px-4 py-2.5 text-sm font-semibold transition-all"> Estimate </button>
        </div>
        <div id="calorie-result" class="mt-3 hidden">
         <div class="bg-emerald-900/30 border border-emerald-500/20 rounded-xl p-3">
          <div class="flex justify-between items-center"><span class="text-sm text-gray-300" id="food-name"></span> <span class="text-emerald-400 font-bold" id="food-cals"></span>
          </div>
          <div class="flex gap-3 mt-2 text-xs text-gray-500"><span>🥩 P: <span id="food-protein">0</span>g</span> <span>🍞 C: <span id="food-carbs">0</span>g</span> <span>🧈 F: <span id="food-fat">0</span>g</span>
          </div><button onclick="logEstimatedFood()" class="mt-2 text-xs text-emerald-400 hover:text-emerald-300 font-semibold">+ Log this meal</button>
         </div>
        </div>
       </div><!-- Meal Photo Recognition -->
       <div class="card-dark rounded-2xl p-5 anim-up anim-up-3">
        <h3 class="font-heading text-sm text-emerald-400 mb-3">📸 Photo Meal Scanner</h3>
        <p class="text-xs text-gray-500 mb-3">Upload a photo to identify meals</p>
        <div class="flex gap-2">
         <label class="flex-1 bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl px-4 py-2.5 text-sm font-semibold transition-all cursor-pointer text-center"> <input type="file" accept="image/*" id="meal-photo-input" onchange="analyzePhotoMeal()" style="display:none;"> 📤 Upload Photo </label> <button id="camera-btn" onclick="openCameraCapture()" class="bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl px-4 py-2.5 text-sm font-semibold transition-all"> 📷 Camera </button>
        </div>
        <div id="photo-preview" class="mt-3 hidden">
         <img id="photo-img" class="w-full rounded-lg max-h-48 object-cover border border-emerald-500/30">
         <div class="mt-2 text-xs text-gray-400">
          Photo uploaded ✓
         </div>
        </div>
        <div id="photo-result" class="mt-3 hidden">
         <div class="bg-emerald-900/30 border border-emerald-500/20 rounded-xl p-3">
          <div class="flex justify-between items-center"><span class="text-sm text-gray-300" id="photo-food-name"></span> <span class="text-emerald-400 font-bold" id="photo-food-cals"></span>
          </div>
          <div class="flex gap-3 mt-2 text-xs text-gray-500"><span>🥩 P: <span id="photo-food-protein">0</span>g</span> <span>🍞 C: <span id="photo-food-carbs">0</span>g</span> <span>🧈 F: <span id="photo-food-fat">0</span>g</span>
          </div>
          <div class="flex gap-2 mt-3">
           <button onclick="logPhotoFood()" class="flex-1 bg-emerald-600 hover:bg-emerald-500 text-white text-xs font-semibold rounded-lg py-2">+ Log Meal</button> <button onclick="clearPhotoData()" class="flex-1 bg-gray-700 hover:bg-gray-600 text-white text-xs font-semibold rounded-lg py-2">Clear</button>
          </div>
         </div>
        </div>
       </div>
      </div><!-- MEALS TAB -->
      <div id="tab-meals" class="tab-content space-y-4" style="display:none;">
       <div class="card-dark rounded-2xl p-5 anim-up">
        <div class="flex items-center justify-between mb-4">
         <h3 class="font-heading text-sm text-emerald-400">🍽️ Today's Meal Plan</h3><button onclick="generateMealPlan()" class="text-xs bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg px-3 py-1.5 font-semibold transition-all flex items-center gap-1"> <i data-lucide="refresh-cw" style="width:12px;height:12px"></i> New Plan </button>
        </div>
        <div id="meal-plan-content" class="space-y-3">
         <p class="text-gray-500 text-sm text-center py-4">Tap "New Plan" to generate a personalized meal plan</p>
        </div>
       </div><!-- Log Custom Meal -->
       <div class="card-dark rounded-2xl p-5 anim-up anim-up-1">
        <h3 class="font-heading text-sm text-emerald-400 mb-3">📝 Log a Meal</h3>
        <div class="space-y-3"><input id="meal-name-input" type="text" placeholder="What did you eat?" class="input-dark w-full rounded-xl px-4 py-2.5 text-sm"> <input id="meal-cal-input" type="number" placeholder="Estimated calories" class="input-dark w-full rounded-xl px-4 py-2.5 text-sm"> <button onclick="logCustomMeal()" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl py-2.5 text-sm font-semibold transition-all"> Log Meal </button>
        </div>
       </div><!-- Today's Logged Meals -->
       <div class="card-dark rounded-2xl p-5 anim-up anim-up-2">
        <h3 class="font-heading text-sm text-emerald-400 mb-3">📋 Today's Log</h3>
        <div id="meals-log-list" class="space-y-2">
         <p class="text-gray-500 text-sm text-center py-2">No meals logged yet today</p>
        </div>
       </div>
      </div><!-- WORKOUT TAB -->
      <div id="tab-workout" class="tab-content space-y-4" style="display:none;">
       <div class="card-dark rounded-2xl p-5 anim-up">
        <div class="flex items-center justify-between mb-4">
         <h3 class="font-heading text-sm text-emerald-400">🏋️ Today's Workout</h3><button onclick="generateWorkout()" class="text-xs bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg px-3 py-1.5 font-semibold transition-all flex items-center gap-1"> <i data-lucide="refresh-cw" style="width:12px;height:12px"></i> New Workout </button>
        </div>
        <div id="workout-plan-content" class="space-y-3">
         <p class="text-gray-500 text-sm text-center py-4">Tap "New Workout" to generate a workout plan</p>
        </div>
       </div><!-- Workout Timer -->
       <div class="card-dark rounded-2xl p-5 anim-up anim-up-1">
        <h3 class="font-heading text-sm text-emerald-400 mb-3">⏱️ Rest Timer</h3>
        <div class="text-center">
         <div class="text-4xl font-heading text-white mb-4" id="timer-display">
          0:30
         </div>
         <div class="flex justify-center gap-3"><button onclick="setTimer(30)" class="bg-gray-800 hover:bg-gray-700 text-white rounded-lg px-3 py-1.5 text-xs">30s</button> <button onclick="setTimer(60)" class="bg-gray-800 hover:bg-gray-700 text-white rounded-lg px-3 py-1.5 text-xs">60s</button> <button onclick="setTimer(90)" class="bg-gray-800 hover:bg-gray-700 text-white rounded-lg px-3 py-1.5 text-xs">90s</button> <button onclick="toggleTimer()" id="timer-btn" class="bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg px-4 py-1.5 text-xs font-semibold">Start</button>
         </div>
        </div>
       </div>
      </div><!-- CHAT TAB -->
      <div id="tab-chat" class="tab-content flex flex-col" style="display:none; height: calc(100% - 1rem);">
       <div class="card-dark rounded-2xl p-4 flex flex-col flex-1 overflow-hidden">
        <div class="flex items-center gap-2 mb-3 flex-shrink-0">
         <div class="w-8 h-8 rounded-full bg-emerald-600 flex items-center justify-center text-sm">
          🤖
         </div>
         <div>
          <h3 class="font-heading text-sm text-emerald-400">AI Health Coach</h3>
          <p class="text-[10px] text-gray-500">Ask me anything about health &amp; fitness</p>
         </div>
        </div>
        <div id="chat-messages" class="flex-1 overflow-auto space-y-3 scrollbar-hide pr-1 mb-3">
         <div class="chat-bubble-ai px-4 py-3 max-w-[85%]">
          <p class="text-sm text-gray-200">Hey! 👋 I'm your AI health coach. Ask me about nutrition, workouts, weight loss, or any health topic!</p>
         </div>
        </div>
        <div class="flex gap-2 flex-shrink-0"><input id="chat-input" type="text" placeholder="Ask about health, nutrition, workouts..." class="input-dark flex-1 rounded-xl px-4 py-2.5 text-sm" onkeydown="if(event.key==='Enter')sendChat()"> <button onclick="sendChat()" class="bg-emerald-600 hover:bg-emerald-500 text-white rounded-xl px-3 py-2.5 transition-all flex items-center justify-center" title="Send message"> <i data-lucide="send" style="width:16px;height:16px"></i> </button> <button id="chat-voice-btn" onclick="handleChatVoice()" class="bg-blue-600 hover:bg-blue-500 text-white rounded-xl px-3 py-2.5 transition-all flex items-center justify-center" title="Click to speak"> <i data-lucide="mic" style="width:16px;height:16px"></i> </button>
        </div>
       </div>
      </div>
     </div><!-- PROGRESS TAB -->
     <div id="tab-progress" class="tab-content space-y-4" style="display:none;">
      <div class="card-dark rounded-2xl p-5 anim-up">
       <h3 class="font-heading text-sm text-emerald-400 mb-3">📏 BMI Calculator</h3>
       <div class="grid grid-cols-2 gap-3 mb-3">
        <div><label class="text-xs text-gray-500 mb-1 block">Weight (kg)</label> <input id="bmi-weight" type="number" placeholder="70" class="input-dark w-full rounded-lg px-3 py-2 text-sm">
        </div>
        <div><label class="text-xs text-gray-500 mb-1 block">Height (cm)</label> <input id="bmi-height" type="number" placeholder="170" class="input-dark w-full rounded-lg px-3 py-2 text-sm">
        </div>
       </div><button onclick="calculateBMI()" class="w-full bg-emerald-600 hover:bg-emerald-500 text-white rounded-lg py-2.5 text-sm font-semibold transition-all mb-3">Calculate BMI</button>
