// ─── REST TIMER ───
function setTimer(sec) {
  timerSeconds = sec;
  timerRunning = false;
  if (timerInterval) clearInterval(timerInterval);
  updateTimerDisplay();
  document.getElementById('timer-btn').textContent = 'Start';
}
function toggleTimer() {
  if (timerRunning) {
    clearInterval(timerInterval);
    timerRunning = false;
    document.getElementById('timer-btn').textContent = 'Start';
  } else {
    timerRunning = true;
    document.getElementById('timer-btn').textContent = 'Pause';
    timerInterval = setInterval(() => {
      timerSeconds--;
      if (timerSeconds <= 0) {
        clearInterval(timerInterval);
        timerRunning = false;
        timerSeconds = 0;
        document.getElementById('timer-btn').textContent = 'Start';
        showToast('⏱️ Time\'s up! Get back to it!');
      }
      updateTimerDisplay();
    }, 1000);
  }
}
function updateTimerDisplay() {
  const m = Math.floor(timerSeconds / 60);
  const s = timerSeconds % 60;
  document.getElementById('timer-display').textContent = `${m}:${s.toString().padStart(2, '0')}`;
}

// ─── AI CHAT ───
function classifyMessage(msg) {
  const m = msg.toLowerCase();
  if (/^(hi|hello|hey|howdy|yo|sup|greetings)/.test(m)) return 'greetings';
  if (/weight\s*loss|lose\s*(weight|fat)|slim|cut|lean|belly\s*fat|fat\s*loss|shred/.test(m)) return 'weight_loss';
  if (/muscle|bulk|gain|mass|grow|hypertrophy|big/.test(m)) return 'muscle_gain';
  if (/protein/.test(m)) return 'protein';
  if (/sleep|insomnia|rest|tired|fatigue/.test(m)) return 'sleep';
  if (/water|hydrat|drink|thirst/.test(m)) return 'water';
  if (/motivat|lazy|can't|give up|stuck|discouraged|discipline/.test(m)) return 'motivation';
  if (/stretch|flex|warm|cool\s*down|mobility|yoga/.test(m)) return 'stretching';
  if (/stress|anxi|relax|meditat|mental|calm|burnout/.test(m)) return 'stress';
  if (/supplement|creatine|vitamin|omega|whey|bcaa/.test(m)) return 'supplements';
  if (/nutri|diet|eat|food|meal|calori|macro|carb|fat/.test(m)) return 'nutrition';
  return 'default';
}

function getAIResponse(msg) {
  const category = classifyMessage(msg);
  const responses = AI_RESPONSES[category] || AI_RESPONSES.default;
  return responses[Math.floor(Math.random() * responses.length)];
}

function addChatBubble(role, text) {
  const container = document.getElementById('chat-messages');
  const div = document.createElement('div');
  div.className = role === 'user'
    ? 'chat-bubble-user px-4 py-3 max-w-[85%] ml-auto anim-up'
    : 'chat-bubble-ai px-4 py-3 max-w-[85%] anim-up';
  // Parse markdown bold
  const html = text.replace(/\*\*(.*?)\*\*/g, '<strong class="text-emerald-300">$1</strong>').replace(/\n/g, '<br>');
  div.innerHTML = `<p class="text-sm text-gray-200">${html}</p>`;
  container.appendChild(div);
  container.scrollTop = container.scrollHeight;
  if (textToSpeechEnabled) speakText(text);
}

function sendChat() {
  const input = document.getElementById('chat-input');
  const msg = input.value.trim();
  if (!msg) return;
  input.value = '';
  addChatBubble('user', msg);
  // Simulate typing delay
  setTimeout(() => {
    const response = getAIResponse(msg);
    addChatBubble('ai', response);
  }, 400 + Math.random() * 600);
}

// ─── PROGRESS TAB ───
function updateWeeklyChart() {
  const container = document.getElementById('weekly-chart');
  const days = [];
  for (let i = 6; i >= 0; i--) {
    const d = new Date(); d.setDate(d.getDate() - i);
    days.push(d.toISOString().slice(0, 10));
  }
  const target = calcBMR();
  let html = '';
  days.forEach(d => {
    const dayData = allData.filter(r => r.date === d && r.type === 'meal');
    const cal = dayData.reduce((s, r) => s + (r.calories || 0), 0);
    const pct = Math.max(Math.min(cal / target * 100, 100), 4);
    const color = cal > 0 ? (cal > target * 1.1 ? '#ef4444' : '#10b981') : '#1e1e35';
    html += `<div class="flex-1 flex flex-col items-center justify-end h-full">
      <div class="text-[9px] text-gray-500 mb-1">${cal > 0 ? cal : ''}</div>
      <div style="height:${pct}%; background:${color}; min-height:4px;" class="w-full rounded-t-md transition-all duration-500"></div>
    </div>`;
  });
  container.innerHTML = html;
}

